{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["react", "react-dom", "node"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true
  },
  "include": [
    "src/panel/**/*",
    "src/types.ts",
    "src/statusTypes.ts",
    "src/poiTypeSelection.ts",
    "src/pluginId.ts"
  ]
}
