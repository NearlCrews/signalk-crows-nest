{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["react", "react-dom", "node"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true
  },
  "include": [
    "src/panel/**/*",
    "src/shared/types.ts",
    "src/status/status-types.ts",
    "src/shared/poi-type-selection.ts",
    "src/shared/plugin-id.ts"
  ]
}
