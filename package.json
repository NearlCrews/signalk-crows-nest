{
  "name": "signalk-crows-nest",
  "version": "0.4.2",
  "description": "Imports Garmin ActiveCaptain, OpenSeaMap, USCG Light List, and NOAA ENC Direct points of interest as Signal K notes resources, with proximity and route-corridor hazard alarms.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "public"
  ],
  "scripts": {
    "build": "npm run build:plugin && npm run build:panel",
    "build:plugin": "tsc",
    "build:panel": "webpack --config webpack.config.cjs",
    "watch:panel": "webpack --watch --mode development --config webpack.config.cjs",
    "clean": "rm -rf dist && rm -f public/*.js public/*.js.map public/*.LICENSE.txt",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.panel.json && tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "node --import tsx --test test/*.test.ts",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-plugin-configurator",
    "signalk-category-chart-plotters",
    "signalk-category-notifications",
    "points-of-interest",
    "notes",
    "chart-overlay",
    "activecaptain",
    "openseamap",
    "uscg",
    "noaa",
    "freeboard",
    "proximity-alarm",
    "route-corridor",
    "marina",
    "anchorage",
    "hazard"
  ],
  "signalk-plugin-enabled-by-default": false,
  "signalk": {
    "displayName": "Crow's Nest"
  },
  "engines": {
    "node": ">=20.3.0"
  },
  "author": {
    "name": "Nearl Crews",
    "email": "NearlCrews@users.noreply.github.com"
  },
  "contributors": [
    "Paul Willems (original author of signalk-activecaptain-resources)"
  ],
  "license": "MIT",
  "homepage": "https://github.com/NearlCrews/signalk-crows-nest#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NearlCrews/signalk-crows-nest.git"
  },
  "bugs": {
    "url": "https://github.com/NearlCrews/signalk-crows-nest/issues"
  },
  "dependencies": {
    "handlebars": "^4.7.9",
    "lru-cache": "^11.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@signalk/server-api": "^2.24.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "babel-loader": "^10.1.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "neostandard": "^0.13.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "webpack": "^5.107.1",
    "webpack-cli": "^7.0.2"
  }
}
