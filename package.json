{
  "name": "signalk-crows-nest",
  "version": "0.10.0",
  "description": "Imports Garmin ActiveCaptain, OpenSeaMap, USCG Light List, and NOAA ENC Direct points of interest as Signal K notes resources, with proximity, route-corridor, and bridge air-draft alarms.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "public",
    "assets",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "npm run build:plugin && npm run build:panel && npm run build:icons",
    "build:plugin": "tsc",
    "build:panel": "webpack --config webpack.config.cjs",
    "build:icons": "node scripts/copy-icons.mjs",
    "watch:panel": "webpack --watch --mode development --config webpack.config.cjs",
    "clean": "node scripts/clean.mjs",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.panel.json && tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "node --import tsx --test test/*.test.ts",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-plugin-configurator",
    "signalk-category-chart-plotters",
    "signalk-category-notifications",
    "points-of-interest",
    "notes",
    "chart-overlay",
    "activecaptain",
    "openseamap",
    "uscg",
    "noaa",
    "freeboard",
    "proximity-alarm",
    "route-corridor",
    "marina",
    "anchorage",
    "hazard"
  ],
  "signalk-plugin-enabled-by-default": false,
  "signalk": {
    "displayName": "Crow's Nest",
    "appIcon": "assets/icons/icon-192.png",
    "screenshots": [
      "assets/screenshots/freeboard-activecaptain-hazard.png",
      "assets/screenshots/freeboard-uscg-light-list.png",
      "assets/screenshots/admin-panel.png"
    ],
    "recommends": [
      "@signalk/freeboard-sk",
      "signalk-nmea2000-emitter-cannon",
      "signalk-binnacle"
    ]
  },
  "engines": {
    "node": ">=20.3.0"
  },
  "author": {
    "name": "Nearl Crews",
    "email": "NearlCrews@users.noreply.github.com"
  },
  "contributors": [
    "Paul Willems (original author of signalk-activecaptain-resources)"
  ],
  "license": "MIT",
  "homepage": "https://github.com/NearlCrews/signalk-crows-nest#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NearlCrews/signalk-crows-nest.git"
  },
  "bugs": {
    "url": "https://github.com/NearlCrews/signalk-crows-nest/issues"
  },
  "funding": {
    "type": "buymeacoffee",
    "url": "https://www.buymeacoffee.com/nearlcrews"
  },
  "dependencies": {
    "handlebars": "^4.7.9",
    "lru-cache": "^11.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@signalk/server-api": "^2.25.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "babel-loader": "^10.1.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "neostandard": "^0.13.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  }
}
